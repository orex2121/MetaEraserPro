@echo off
:: Устанавливаем кодировку UTF-8 для корректного русского текста
chcp 65001 > nul

echo ==================================================
echo      УСТАНОВКА ЗАВИСИМОСТЕЙ (requirements.txt)
echo ==================================================
echo.

:: Проверка Python
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [!] ОШИБКА: Python не найден. Проверьте установку.
    pause
    exit /b
)

echo [>] Проверка и установка библиотек...
echo     (Это может занять некоторое время)
echo.

:: Установка библиотек с флагом --quiet (убирает лишний текст) 
:: и --no-warn-script-location (убирает желтые предупреждения)
python -m pip install -r requirements.txt --quiet --no-warn-script-location --disable-pip-version-check

if %errorlevel% equ 0 (
    echo.
    echo --------------------------------------------------
    echo [✅] ВСЕ БИБЛИОТЕКИ УСПЕШНО УСТАНОВЛЕНЫ!
    echo --------------------------------------------------
) else (
    echo.
    echo --------------------------------------------------
    echo [❌] ПРОИЗОШЛА ОШИБКА ПРИ УСТАНОВКЕ.
    echo --------------------------------------------------
)

echo.
echo Нажмите любую клавишу, чтобы выйти...
pause > nul